{
  "slug": "rsi_reversion",
  "name": "RSI Reversion",
  "category": "mean_reversion",
  "version": "1.0.0",
  "description": "Mean-reversion strategy that enters when RSI returns from oversold or overbought extremes.",
  "direction": ["long", "short"],
  "class_name": "RSIReversionStrategy",
  "timeframes": ["15m", "1h", "4h"],
  "symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT", "SPY"],
  "required_columns": ["open", "high", "low", "close", "volume"],
  "outputs": [
    "entry_long",
    "entry_short",
    "exit_long",
    "exit_short",
    "rsi"
  ],
  "parameters": {
    "rsi_period": {
      "type": "int",
      "default": 14,
      "min": 2,
      "max": 100,
      "step": 1,
      "optimize": true,
      "description": "RSI smoothing period."
    },
    "oversold": {
      "type": "float",
      "default": 30.0,
      "min": 0,
      "max": 49,
      "step": 0.5,
      "optimize": true,
      "description": "Oversold threshold for long setup recovery."
    },
    "overbought": {
      "type": "float",
      "default": 70.0,
      "min": 51,
      "max": 100,
      "step": 0.5,
      "optimize": true,
      "description": "Overbought threshold for short setup recovery."
    },
    "exit_mid": {
      "type": "float",
      "default": 50.0,
      "min": 1,
      "max": 99,
      "step": 0.5,
      "optimize": true,
      "description": "Midline level used for mean-reversion exits."
    },
    "allow_short": {
      "type": "bool",
      "default": true,
      "optimize": false,
      "description": "Enable symmetric short entries and exits."
    }
  }
}

